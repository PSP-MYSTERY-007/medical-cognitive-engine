# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://clintrial:clintrial@localhost:5432/clintrial?schema=public"

# Auth
JWT_ACCESS_SECRET="change_me_access"
JWT_REFRESH_SECRET="change_me_refresh"
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# Optional: restrict registration to a university email domain
# Leave blank to disable the check.
UNIVERSITY_EMAIL_DOMAIN=""

# Assistant ( the existing python service from medspeakai)
# It exposes: POST /{laptop_code}/{mode}/{session_id}
ASSISTANT_BASE_URL="http://127.0.0.1:8000"
ASSISTANT_LAPTOP_CODE="STUDENT_LAPTOP_01"
ASSISTANT_MODE="chat"

# Redis (optional; can run without it)
REDIS_URL="redis://127.0.0.1:6379"
USE_REDIS=false
